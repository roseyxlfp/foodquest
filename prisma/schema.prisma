generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Score {
  id         Int      @id @default(autoincrement())
  playerName String
  money      Int
  correct    Int
  total      Int
  plants     Int
  mascots    Int
  createdAt  DateTime @default(now())

  @@index([money])
}
